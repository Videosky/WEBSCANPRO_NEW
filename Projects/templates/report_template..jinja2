<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WebScanPro - AI Enhanced Vulnerability Report</title>
    <script src="https://cdn.plot.ly/plotly-latest.min.js"></script>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; }
        .header { background: #2c3e50; color: white; padding: 20px; border-radius: 5px; }
        .summary-cards { display: flex; gap: 20px; margin: 20px 0; }
        .card { flex: 1; padding: 15px; border-radius: 5px; text-align: center; }
        .high-confidence { background: #d4edda; border: 1px solid #c3e6cb; }
        .medium-confidence { background: #fff3cd; border: 1px solid #ffeaa7; }
        .low-confidence { background: #f8d7da; border: 1px solid #f5c6cb; }
        table { width: 100%; border-collapse: collapse; margin: 20px 0; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #ddd; }
        th { background-color: #f2f2f2; }
        .match { color: #28a745; }
        .mismatch { color: #dc3545; }
        .visualization { margin: 30px 0; }
    </style>
</head>
<body>
    <div class="header">
        <h1>🔍 WebScanPro - AI Enhanced Vulnerability Report</h1>
        <p>Generated: {{ timestamp }}</p>
    </div>

    <div class="summary-cards">
        <div class="card high-confidence">
            <h3>High Confidence</h3>
            <p>{{ high_confidence_count }} findings</p>
        </div>
        <div class="card medium-confidence">
            <h3>Medium Confidence</h3>
            <p>{{ medium_confidence_count }} findings</p>
        </div>
        <div class="card low-confidence">
            <h3>Low Confidence</h3>
            <p>{{ low_confidence_count }} findings</p>
        </div>
    </div>

    <h2>ML Confidence Distribution</h2>
    <div id="confidenceChart" class="visualization"></div>

    <h2>Vulnerability Findings with ML Predictions</h2>
    <table>
        <thead>
            <tr>
                <th>Vuln ID</th>
                <th>Vulnerability</th>
                <th>True Severity</th>
                <th>ML Prediction</th>
                <th>Confidence</th>
                <th>Status</th>
                <th>Affected URL</th>
            </tr>
        </thead>
        <tbody>
            {% for finding in findings_table %}
            <tr>
                <td>{{ finding.vuln_id }}</td>
                <td>{{ finding.vuln_name }}</td>
                <td>{{ finding.severity }}</td>
                <td>{{ finding.ml_pred_label }}</td>
                <td>
                    <div style="background: #e9ecef; border-radius: 5px;">
                        <div style="background: {% if finding.ml_confidence >= 0.85 %}#28a745{% elif finding.ml_confidence >= 0.60 %}#ffc107{% else %}#dc3545{% endif %}; 
                                    width: {{ (finding.ml_confidence * 100)|round }}%; 
                                    padding: 5px; color: white; text-align: center; border-radius: 5px;">
                            {{ (finding.ml_confidence * 100)|round }}%
                        </div>
                    </div>
                </td>
                <td class="{% if finding.severity == finding.ml_pred_label %}match{% else %}mismatch{% endif %}">
                    {% if finding.severity == finding.ml_pred_label %}Match{% else %}Review Needed{% endif %}
                </td>
                <td>{{ finding.affected_url }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <script>
        // Interactive Plotly chart for confidence distribution
        var confidenceData = [{
            x: {{ findings_table|map(attribute='ml_confidence')|list }},
            type: 'histogram',
            nbinsx: 20,
            marker: { color: '#3498db' }
        }];

        var layout = {
            title: 'Distribution of ML Confidence Scores',
            xaxis: { title: 'Confidence Score' },
            yaxis: { title: 'Frequency' }
        };

        Plotly.newPlot('confidenceChart', confidenceData, layout);
    </script>
</body>
</html>